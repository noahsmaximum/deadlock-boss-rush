<!-- Boss Rush — Upgrade Station. Overrides the native shop: hides the native presentation (vcss) and
     overlays a custom "arcane altar" modal. Native C++ item lists stay in-tree (collapsed) so JS
     (bossrush_probe.js) can read owned-item data to drive the custom UI. -->
<root>
	<styles>
		<include src="s2r://panorama/styles/citadel_base_styles.vcss_c" />
		<include src="s2r://panorama/styles/citadel_hud_hero_shop.vcss_c" />
		<include src="s2r://panorama/styles/ability_icons.vcss_c" />
		<include src="s2r://panorama/styles/bossrush_shop.vcss_c" />
	</styles>
	<snippets>
		<snippet name="RecentPurchase">
			<Panel class="recentPurchase">
				<Label class="recentTimePurchased" text="{s:time_purchased}" />
				<CitadelHeroImage id="RecentPurchaseHeroImage" heroimagestyle="small" />
				<Panel class="mod_icon" />
				<Label class="recentModPurchaseName" text="{s:recent_mod_name}" />
				<Label class="recentModTierCost" text="{s:recent_tier_purchased}" />
			</Panel>
		</snippet>
	</snippets>
	<CitadelHudHeroShop class="CitadelHudHeroShop gShopOpen" oncancel="CitadelExitUpgradeShop();" disallowedstyleflags="hover,descendantfocus" onactivate="">
		<GlobalClassListener classes="gEditingBuilds gScoreboardOpen gShopOpen" />
		<Panel id="Shop" disallowedstyleflags="hover,descendantfocus">
			<Panel id="MainPanel" disallowedstyleflags="hover,descendantfocus">
				<Panel id="ShopModsContainer" disallowedstyleflags="hover,descendantfocus">
					<Panel id="ShopNavigation" disallowedstyleflags="hover,descendantfocus">
						<Panel id="FavoritesNav" class="NavigationButton" onmouseactivate="CitadelShopModsActivate( EItemSlotType_Favorites ); PlaySoundEffect( &apos;UI.Shop.Mod.Starred.Click&apos; );">
							<Panel class="ShopNavigationTab ShopNavigationTabBackground" />
							<Panel class="ShopNavigationTab ShopNavigationTabEdgeOverlay" />
							<Panel class="ShopNavigationTab ShopNavigationTabIcon" />
						</Panel>
						<Panel id="WeaponNav" class="NavigationButton" onmouseactivate="CitadelShopModsActivate( EItemSlotType_WeaponMod ); PlaySoundEffect( &apos;UI.Shop.Mod.Weapon.Click&apos; );">
							<Panel class="ShopNavigationTab ShopNavigationTabBackground" />
							<Panel class="ShopNavigationTab ShopNavigationTabEdgeOverlay" />
							<Panel class="ShopNavigationTab ShopNavigationTabIcon" />
						</Panel>
						<Panel id="ArmorNav" class="NavigationButton" onmouseactivate="CitadelShopModsActivate( EItemSlotType_Armor ); PlaySoundEffect( &apos;UI.Shop.Mod.Vitality.Click&apos; );">
							<Panel class="ShopNavigationTab ShopNavigationTabBackground" />
							<Panel class="ShopNavigationTab ShopNavigationTabIcon" />
							<Panel class="ShopNavigationTab ShopNavigationTabEdgeOverlay" />
						</Panel>
						<Panel id="TechNav" class="NavigationButton" onmouseactivate="CitadelShopModsActivate( EItemSlotType_Tech ); PlaySoundEffect( &apos;UI.Shop.Mod.Magic.Click&apos; );">
							<Panel class="ShopNavigationTab ShopNavigationTabBackground" />
							<Panel class="ShopNavigationTab ShopNavigationTabIcon" />
							<Panel class="ShopNavigationTab ShopNavigationTabEdgeOverlay" />
						</Panel>
						<Panel id="SearchNav" class="NavigationButton" onmouseactivate="CitadelShopModsActivate( EItemSlotType_All ); PlaySoundEffect( &apos;UI.Shop.Mod.Search.Click&apos; );" onmouseover="UIShowTextTooltip( #CitadelShopSearch)" onmouseout="UIHideTextTooltip();" />
						<Panel id="ToggleContainer" onactivate="CitadelToggleComponentGroupingInShop();">
							<Panel id="ShowCategories" class="viewToggle category_view" onmouseover="UIShowTextTooltip( #Citadel_Shop_Sort_Tooltip_Categories )" onmouseout="UIHideTextTooltip()" />
							<Panel id="ShowTiers" class="viewToggle tiers_view" onmouseover="UIShowTextTooltip( #Citadel_Shop_Sort_Tooltip_Tier )" onmouseout="UIHideTextTooltip()" />
						</Panel>
					</Panel>
					<Panel id="ShopModListsContainer" disallowedstyleflags="hover,descendantfocus">
						<Label class="HeroFavoritesHeaderLabel" text="{s:hero_name}&apos;s Recommended Mods" />
						<CitadelShopModsList id="ShopModsListWeapon" category="Weapon" />
						<CitadelShopModsList id="ShopModsListArmor" category="Armor" />
						<CitadelShopModsList id="ShopModsListTech" category="Tech" />
						<CitadelShopModsBuild id="ShopModsSelectedBuild" />
						<CitadelShopModsList id="ShopModsListAll" category="All" />
						<Panel id="SearchHeader">
							<Panel id="SearchExamples">
								<Label class="searchTitle" text="#CitadelShopSearch" />
								<Label html="true" class="SearchExampleHeader" text="#CitadelShop_SearchExampleAlt" />
							</Panel>
							<Panel id="SearchContainer">
								<Panel id="SearchBox">
									<Panel id="ShopSearchIcon" onactivate="SetSearchFocus();" />
									<TextEntry id="SearchTextEntry" acceptsfocus="true" acceptsinput="true" placeholder="#CitadelShopSearch" ontextentrychange="CitadelShopSearchTextEntryChanged()" onfocus="CitadelShopSearchTextEntryChanged()" />
									<Button id="ClearSearchButton" onactivate="CitadelShopSearchTextEntryClear();" />
								</Panel>
							</Panel>
						</Panel>
					</Panel>
				</Panel>
			</Panel>
			<Panel id="NavPanel" class="TopBottomFlow" hittest="false">
				<CitadelHeroScenePanelNew id="HeroScenePanel" heroscenestyle="Shop" hittest="false" />
				<Panel id="ShopNav">
					<Panel class="ShopHeader">
						<Panel class="ShopName" />
						<CitadelHudSoulAPContainer id="GoldAPContainer" />
					</Panel>
					<Panel class="ReadOnlyShop">
						<Label class="ReadOnlyTitle" text="#BrowseItems_Title" />
						<Label class="ReadOnlyDesc" text="#BrowseItems_Desc" />
					</Panel>
					<Panel class="APHeader">
						<Panel class="SectionTitle">
							<Label class="SectionLabel" text="Purchase Items" />
						</Panel>
					</Panel>
				</Panel>
				<Panel id="RecentPurchasesPanel">
					<Label id="RecentPurchases" text="#Citadel_Hud_RecentPurchases" />
					<Panel id="RecentPurchasesContainer" />
				</Panel>
				<Panel id="HeroPanel">
					<Image id="HeroImage" scaling="stretch-to-fit-y-preserve-aspect" />
					<Panel id="SoulsContainer">
						<Panel id="SoulAmount">
							<Panel class="SoulsImage" />
							<Label class="AbilitiesLabel" text="{i:total_souls}" />
						</Panel>
						<Label class="totalSouls" text="Total Souls Collected" />
						<Panel id="SoulRewards">
							<Label text="View Soul Rewards" />
						</Panel>
						<Panel id="HeroStatsBtn" onmouseout="CitadelHideHeroStatsTooltip();">
							<Label text="View Hero Stats" />
						</Panel>
					</Panel>
				</Panel>
				<Panel class="streetbrawl_info_container">
					<Panel class="streetbrawl_round_start_timer">
						<Label class="streetbrawl_timer_text" text="#Citadel_Hud_StreetBrawlShopCountdown" />
						<Panel class="streetbrawl_countdown_container">
							<Label class="streetbrawl_countdown" text="{d:sb_countdown}" />
						</Panel>
					</Panel>
				</Panel>
				<Panel id="InCombatAlert">
					<Label text="#Citadel_Shop_InCombat_Alert" />
				</Panel>
			</Panel>
			<Panel id="BackButton">
				<Panel id="LeftCommandPanel" class="LeftRightFlow commandPanel" onactivate="CitadelExitUpgradeShop();">
					<Panel class="FooterCommand DefaultESC light">
						<CitadelBinding id="BackBinding" action="MenuBack" />
						<Label class="FooterCommandLabel" text="#menu_exit_db_page" />
					</Panel>
				</Panel>
			</Panel>
		</Panel>
		<Panel id="Outline" hittest="false" />

		<!-- ══ Boss Rush custom Upgrade Station modal (overlays the hidden native shop; static shell) ══ -->
		<Panel class="BRStation">
			<Panel class="BRCenter">

				<!-- Header sits OUTSIDE the modal frame -->
				<Panel class="BRHeader">
					<Label class="BRTitle" text="◆  UPGRADE STATION  ◆" />
					<Label class="BRSubtitle" text="Loot powers you — spend Souls to enhance what you hold." />
				</Panel>

				<Panel class="BRModal catWeapon">
					<Panel class="BRTabBar">
						<Panel class="BRTab BRTabWeapon BRTabActive"><Label class="BRTabLabel" text="FAIRWAY" /></Panel>
						<Panel class="BRTab BRTabArmor"><Label class="BRTabLabel" text="MPS" /></Panel>
						<Panel class="BRTab BRTabTech"><Label class="BRTabLabel" text="CURIOSITY CATALOG" /></Panel>
						<Panel class="BRTab BRTabLegendary"><Label class="BRTabLabel" text="LEGENDARIES" /></Panel>
						<Label class="BRSouls" text="◈ 2,248" />
					</Panel>

					<Panel class="BRBody">
						<Panel class="BRLeft">
							<Panel class="BRGridHeader">
								<Label class="BRGridTitle" text="OWNED · FAIRWAY" />
								<Label class="BRHeld" text="8 HELD" />
							</Panel>
							<!-- Tiles are built by bossrush_probe.js from the player's real owned items. -->
							<Panel class="BRGrid" />
						</Panel>

						<Panel class="BRDetail">
							<Panel class="BRDetailHead">
								<Label class="BRDetailName" text="EMBER SIGIL" />
								<Label class="BRDetailTier" text="TIER 2" />
							</Panel>
							<Panel class="BRDetailMetaRow">
								<Label class="BRDetailPrice" text="◈ 6,400" />
								<Label class="BRDetailCat" text="FAIRWAY" />
							</Panel>
							<Panel class="BRDetailIcon" />
							<Label class="BRDetailDesc" text="Rounds ignite on impact, searing armor with the Archmother's flame." />
							<Panel class="BRStatRow">
								<Panel class="BRStat"><Label class="BRStatVal" text="+14%" /><Label class="BRStatLbl" text="BURN DMG" /></Panel>
								<Panel class="BRStat"><Label class="BRStatVal" text="3.0s" /><Label class="BRStatLbl" text="SCORCH" /></Panel>
							</Panel>
							<Panel class="BRActionBtn"><Panel class="BRActionInner"><Panel class="BRActionArrow" /><Label class="BRActionLbl" text="ENHANCE" /></Panel></Panel>
						</Panel>
					</Panel>

					<Label class="BRFooter" text="ESC / B — Close" />
				</Panel>
			</Panel>
		</Panel>
	</CitadelHudHeroShop>
	<scripts>
		<include src="s2r://panorama/scripts/bossrush_probe.js" />
	</scripts>
</root>
